// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

enum GoalStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActionItemStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String?
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  avatarUrl    String?

  workspaces    WorkspaceMember[]
  goals         Goal[]            @relation("GoalOwner")
  announcements Announcement[]    @relation("AnnouncementAuthor")
  comments      Comment[]
  reactions     Reaction[]
  createdItems  ActionItem[]      @relation("ActionItemCreator")
  assignedItems ActionItem[]      @relation("ActionItemAssignee")
  notifications Notification[]    @relation("UserNotifications")
  auditLogs     AuditLog[]        @relation("UserAuditLogs")
}

model Notification {
  id        String   @id @default(uuid())
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       WorkspaceMember[]
  goals         Goal[]
  announcements Announcement[]
  actionItems   ActionItem[]
  auditLogs     AuditLog[]     @relation("WorkspaceAuditLogs")
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  role        Role      @default(MEMBER)
  joinedAt    DateTime  @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Goal {
  id          String     @id @default(uuid())
  title       String
  dueDate     DateTime?
  status      GoalStatus @default(TODO)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  ownerId     String
  owner       User       @relation("GoalOwner", fields: [ownerId], references: [id])
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  milestones  Milestone[]
  actionItems ActionItem[]
}

model Milestone {
  id        String   @id @default(uuid())
  title     String
  progress  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  content     String
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId    String
  author      User     @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  comments    Comment[]
  reactions   Reaction[]
}

model Comment {
  id             String       @id @default(uuid())
  content        String
  createdAt      DateTime     @default(now())
  
  authorId       String
  author         User         @relation(fields: [authorId], references: [id])
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
}

model Reaction {
  id             String       @id @default(uuid())
  emoji          String
  createdAt      DateTime     @default(now())

  userId         String
  user           User         @relation(fields: [userId], references: [id])
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId, emoji])
}

model ActionItem {
  id          String           @id @default(uuid())
  title       String
  description String?
  status      ActionItemStatus @default(TODO)
  priority    Priority         @default(MEDIUM)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  assigneeId  String?
  assignee    User?            @relation("ActionItemAssignee", fields: [assigneeId], references: [id])
  creatorId   String
  creator     User             @relation("ActionItemCreator", fields: [creatorId], references: [id])
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  goalId      String?
  goal        Goal?            @relation(fields: [goalId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String   // e.g. "CREATE_GOAL", "DELETE_ACTION_ITEM"
  entityType  String   // e.g. "GOAL", "ACTION_ITEM"
  entityId    String   // The ID of the affected entity
  details     String?  // JSON string or description
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation("UserAuditLogs", fields: [userId], references: [id])
  workspaceId String
  workspace   Workspace @relation("WorkspaceAuditLogs", fields: [workspaceId], references: [id], onDelete: Cascade)
}
